    <canvas id="cursorCanvas"></canvas>

    <script>
        const canvas = document.getElementById('cursorCanvas');
        const ctx = canvas.getContext('2d');
        const SIZE = 80;
        canvas.width = SIZE;
        canvas.height = SIZE;

        Object.assign(canvas.style, {
            position: 'fixed',
            pointerEvents: 'none',
            zIndex: '99999',
            transform: 'translate(-4px, -4px)'
        });

        const cols = Math.floor(SIZE / 8);
        const drops = Array(cols).fill(0).map(() => Math.random() * -10);

        document.addEventListener('mousemove', e => {
            canvas.style.left = e.clientX + 'px';
            canvas.style.top  = e.clientY + 'px';
        });

        function getPointerPath() {
            const p = new Path2D();
            p.moveTo(6, 4);
            p.lineTo(6, 38);
            p.lineTo(14, 28);
            p.lineTo(19, 42);
            p.lineTo(24, 40);
            p.lineTo(19, 26);
            p.lineTo(30, 26);
            p.closePath();
            return p;
        }

        function draw() {
            ctx.clearRect(0, 0, SIZE, SIZE);

            const pointer = getPointerPath();

            // Fill pointer solid black background
            ctx.save();
            ctx.fillStyle = '#000000';
            ctx.fill(pointer);
            ctx.restore();

            // Clip ALL matrix rain to inside the pointer shape
            ctx.save();
            ctx.clip(pointer);

            ctx.font = 'bold 8px JetBrains Mono, monospace';
            for (let i = 0; i < drops.length; i++) {
                const char = Math.random() > 0.5 ? '1' : '0';
                ctx.fillStyle = i % 4 === 0 ? '#ffffff' : '#00ff41';
                ctx.shadowColor = '#00ff41';
                ctx.shadowBlur = 4;
                ctx.fillText(char, i * 8, drops[i] * 8);
                if (drops[i] * 8 > SIZE && Math.random() > 0.7) drops[i] = 0;
                drops[i] += 0.5;
            }

            ctx.restore();

            // Draw glowing green pointer outline on top
            ctx.save();
            ctx.strokeStyle = '#00ff41';
            ctx.lineWidth = 1.5;
            ctx.shadowColor = '#00ff41';
            ctx.shadowBlur = 12;
            ctx.stroke(pointer);
            ctx.restore();
        }

        setInterval(draw, 40);
    </script>

