@{
    ViewData["Title"] = "CONTACT";
}

@section Scripts {
    <link rel="stylesheet" href="~/css/contact.css" asp-append-version="true" />
    <script src="~/js/contact.js" asp-append-version="true"></script>
}

<!-- Main Contact Section -->
<section id="contact" class="stack-card contact-section" data-title="CONTACT">
    <div class="contact-container">
        <div class="container">

            <!-- Header -->
            <header class="contact-header">
                <h1 class="glitch-text" data-text="LET'S_WORK_TOGETHER">LET'S_WORK_TOGETHER</h1>
                <p class="status-bar">
                    <span class="cmd-prompt">></span> STATUS: <span class="status-online">OPEN_FOR_OPPORTUNITIES</span>
                </p>
            </header>

            <div class="contact-grid">

                <!-- Left Column: Availability & Preferences -->
                <div class="contact-left">

                    <!-- Availability List -->
                    <div class="data-block">
                        <h2 class="block-title">/// CURRENTLY_OPEN_TO:</h2>
                        <ul class="cyber-list check-list">
                            <li>Remote full-time positions</li>
                            <li>Freelance projects (web development + SEO)</li>
                            <li>Contract work</li>
                            <li>Consulting on SEO strategy</li>
                        </ul>
                    </div>

                    <!-- Best For List -->
                    <div class="data-block mt-4">
                        <h2 class="block-title">/// BEST_MATCH_FOR:</h2>
                        <ul class="cyber-list dash-list">
                            <li>Web application development with SEO consideration</li>
                            <li>Technical SEO audits and implementation</li>
                            <li>Full-stack development (ASP.NET, React)</li>
                            <li>Marketing technology integration</li>
                            <li>Growth-focused engineering</li>
                        </ul>
                    </div>

                </div>

                <!-- Right Column: Contact Terminal -->
                <div class="contact-right">
                    <div class="terminal-card">
                        <div class="terminal-header">
                            <span class="term-title">comm_link_v1.0.exe</span>
                            <div class="term-controls">
                                <span></span><span></span><span></span>
                            </div>
                        </div>

                        <div class="terminal-body">

                            <div class="term-row">
                                <span class="term-label">RESPONSE_TIME:</span>
                                <span class="term-value highlight-anim">WITHIN 24 HOURS</span>
                            </div>

                            <div class="term-separator"></div>

                            <div class="term-row contact-row">
                                <span class="term-label">EMAIL_UPLINK:</span>
                                <div class="copy-wrapper">
                                    <a href="mailto:mondokashamil@gmail.com" class="term-link">mondokashamil@gmail.com</a>
                                    <button class="copy-btn" data-clipboard="mondokashamil@gmail.com" aria-label="Copy Email">
                                        <i class="far fa-copy"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="term-row contact-row">
                                <span class="term-label">SECURE_LINE:</span>
                                <div class="copy-wrapper">
                                    <a href="tel:+260965200082" class="term-link">+260 965 200 082</a>
                                    <button class="copy-btn" data-clipboard="+260 965 200 082" aria-label="Copy Phone">
                                        <i class="far fa-copy"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="term-row">
                                <span class="term-label">PHYSICAL_NODE:</span>
                                <span class="term-value">Lusaka, Zambia <span class="text-muted">(Remote-ready)</span></span>
                            </div>

                            <div class="term-actions">
                                <a href="/docs/Alexander_Shamil_Mondoka_Resume.pdf" target="_blank" class="cyber-btn primary">
                                    <i class="fas fa-file-download"></i> DOWNLOAD_CV
                                </a>
                                <a href="https://github.com" target="_blank" class="cyber-btn outline">
                                    <i class="fab fa-github"></i> GITHUB
                                </a>
                                <a href="https://linkedin.com" target="_blank" class="cyber-btn outline">
                                    <i class="fab fa-linkedin"></i> LINKEDIN
                                </a>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>