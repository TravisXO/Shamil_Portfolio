<!-- Section 6: Contact / Communication Uplink -->
<section id="contact" class="stack-card contact-section" data-title="CONTACT">
    <div class="container-fluid px-4">
        <h2 class="section-title font-monospace text-accent mb-5 text-center fade-in-on-scroll glitch-text" data-text="/// COMMUNICATION_UPLINK">/// COMMUNICATION_UPLINK</h2>

        <div class="row justify-content-center">
            <div class="col-xl-10">
                <div class="contact-container fade-in-on-scroll">
                    <div class="row g-0">
                        <!-- CTA Column -->
                        <div class="col-lg-5">
                            <div class="cta-panel">
                                <h3 class="cta-header">READY TO<br>DEPLOY?</h3>
                                <p class="cta-subtext">
                                    Your digital infrastructure needs an architect, not just a builder. Secure a secure line and let's upgrade your operational capacity.
                                </p>
                                <div class="cta-status">
                                    <div class="status-light"></div>
                                    <span>ENCRYPTED_LINE::OPEN</span>
                                </div>
                            </div>
                        </div>

                        <!-- Form Column -->
                        <div class="col-lg-7">
                            <div class="form-panel">
                                <div id="formContent">
                                    <form id="hudContactForm" method="post" action="/Home/Contact">
                                        <div class="hud-form-group">
                                            <label for="name" class="hud-label">CODENAME [NAME]</label>
                                            <input type="text" id="name" name="name" class="hud-input" required placeholder="Enter ID...">
                                        </div>

                                        <div class="hud-form-group">
                                            <label for="email" class="hud-label">FREQUENCY [EMAIL]</label>
                                            <input type="email" id="email" name="email" class="hud-input" required placeholder="name@domain.com">
                                        </div>

                                        <div class="hud-form-group">
                                            <label for="message" class="hud-label">PAYLOAD [MESSAGE]</label>
                                            <textarea id="message" name="message" class="hud-input hud-textarea" required placeholder="Transmission content..."></textarea>
                                        </div>

                                        <button type="submit" id="transmitBtn" class="transmit-btn">
                                            <i class="fas fa-paper-plane"></i>
                                            <span class="btn-text">INITIATE TRANSMISSION</span>
                                        </button>
                                    </form>
                                </div>

                                <div id="submissionSuccess" class="submission-feedback">
                                    <i class="fas fa-check-circle"></i>
                                    <h4>TRANSMISSION_COMPLETE</h4>
                                    <p>Your packet has been secured. Stand by for response.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>