@{
    ViewData["Title"] = "Home Page";
}

@section Scripts {
    <link rel="stylesheet" href="~/css/quick-stats.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/about.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tech-stack.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/projects-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/contact-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/glitch.css" asp-append-version="true" />
    <script src="~/js/quick-stats.js" asp-append-version="true"></script>
    <script src="~/js/tech-stack.js" asp-append-version="true"></script>
    <script src="~/js/projects-index.js" asp-append-version="true"></script>
    <script src="~/js/contact-index.js" asp-append-version="true"></script>
