<!-- Section 2: System Status / Quick Stats -->
<section id="system-stats" class="stack-card quick-stats-section" data-title="SYSTEM_STATS">
    <div class="container-fluid px-4">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">
                <h2 class="section-title font-monospace text-accent mb-5 text-center fade-in-on-scroll glitch-text" data-text="/// SYSTEM_METRICS_DASHBOARD">/// SYSTEM_METRICS_DASHBOARD</h2>

                <div class="stats-grid">
                    <!-- Stat 1 -->
                    <div class="stat-card fade-in-on-scroll">
                        <div class="card-corner top-left"></div>
                        <div class="card-corner bottom-right"></div>

                        <div class="stat-icon-wrapper">
                            <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
                        </div>

                        <div class="stat-content">
                            <div class="stat-value" data-target="2" data-suffix="+">0</div>
                            <div class="stat-label">YEARS_EXP</div>
                            <div class="stat-subtext">Level 2+ Developer</div>
                        </div>

                        <div class="stat-progress-container">
                            <div class="stat-progress-bar"></div>
                        </div>
                    </div>

                    <!-- Stat 2 -->
                    <div class="stat-card fade-in-on-scroll" style="transition-delay: 0.1s;">
                        <div class="card-corner top-left"></div>
                        <div class="card-corner bottom-right"></div>

                        <div class="stat-icon-wrapper">
                            <div class="stat-icon"><i class="fas fa-code"></i></div>
                        </div>

                        <div class="stat-content">
                            <div class="stat-value" data-target="7" data-suffix="+">0</div>
                            <div class="stat-label">LANGUAGES</div>
                            <div class="stat-subtext">C#, JS, Python...</div>
                        </div>

                        <div class="stat-progress-container">
                            <div class="stat-progress-bar"></div>
                        </div>
                    </div>

                    <!-- Stat 3 -->
                    <div class="stat-card fade-in-on-scroll" style="transition-delay: 0.2s;">
                        <div class="card-corner top-left"></div>
                        <div class="card-corner bottom-right"></div>

                        <div class="stat-icon-wrapper">
                            <div class="stat-icon"><i class="fas fa-users"></i></div>
                        </div>

                        <div class="stat-content">
                            <div class="stat-value" data-target="3" data-suffix="+">0</div>
                            <div class="stat-label">CLIENTS</div>
                            <div class="stat-subtext">Measurable Results</div>
                        </div>

                        <div class="stat-progress-container">
                            <div class="stat-progress-bar"></div>
                        </div>
                    </div>

                    <!-- Stat 4 -->
                    <div class="stat-card fade-in-on-scroll" style="transition-delay: 0.3s;">
                        <div class="card-corner top-left"></div>
                        <div class="card-corner bottom-right"></div>

                        <div class="stat-icon-wrapper">
                            <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                        </div>

                        <div class="stat-content">
                            <div class="stat-value" data-target="217" data-suffix="%">0</div>
                            <div class="stat-label">SEO_GROWTH</div>
                            <div class="stat-subtext">Organic Traffic</div>
                        </div>

                        <div class="stat-progress-container">
                            <div class="stat-progress-bar"></div>
                        </div>
                    </div>

                    <!-- Stat 5 -->
                    <div class="stat-card fade-in-on-scroll" style="transition-delay: 0.4s;">
                        <div class="card-corner top-left"></div>
                        <div class="card-corner bottom-right"></div>

                        <div class="stat-icon-wrapper">
                            <div class="stat-icon"><i class="fas fa-server"></i></div>
                        </div>

                        <div class="stat-content">
                            <div class="stat-value" data-target="100" data-suffix="%">0</div>
