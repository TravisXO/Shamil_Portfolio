                                    </div>
                                    <div class="impact-item">
                                        <i class="fas fa-check-circle text-success"></i>
                                        <span>Reduced dependency on paid advertising channels.</span>
                                    </div>
                                    <div class="impact-item">
                                        <i class="fas fa-check-circle text-success"></i>
                                        <span>Established authority positioning in the competitive Zambian safari market.</span>
                                    </div>
                                </div>
                            </div>
                            <!-- Module 3: Tech Specs + Learnings -->
                            <div class="cs-lb-panel" data-lb-index="3" data-lb-title="TECH_SPECS_&_LEARNINGS">
                                <div class="row g-5">
                                    <div class="col-lg-6">
                                        <h4 class="subsection-title">/// TECHNICAL_SPECS</h4>
                                        <div class="tech-spec-grid">
                                            <div class="spec-row">
                                                <span class="spec-key">PLATFORM</span>
                                                <span class="spec-val">Wix (Highly Optimized)</span>
