@{
    ViewData["Title"] = "Case Studies";
}

@section Scripts {
    <link rel="stylesheet" href="~/css/case-study.css" asp-append-version="true" />
    <script src="~/js/case-study.js" asp-append-version="true"></script>
    <script src="~/js/case-study-strategy.js" asp-append-version="true"></script>
}

<!-- ================================================== -->
<!-- STRATEGY MODULE LIGHTBOX (slider VIEW_MODULE btns) -->
<!-- ================================================== -->
<div id="cs-strategy-lightbox" role="dialog" aria-modal="true" aria-label="Strategy Module Detail">
    <div class="cs-slb-panel">

        <!-- Header -->
        <div class="cs-slb-header">
            <span class="cs-slb-counter font-monospace">01 / 05</span>
            <p class="cs-slb-header-title">/// STRATEGY_MODULE</p>
            <button class="cs-slb-close" aria-label="Close">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <!-- Body — centred content injected by JS -->
        <div class="cs-slb-body">
            <div class="cs-slb-content">
                <div class="slb-icon-wrap">
                    <i class="slb-dyn-icon fas fa-cogs"></i>
                </div>
                <span class="slb-chip slb-dyn-chip font-monospace">MOD_4A</span>
                <h3 class="slb-dyn-title">TECH SEO FOUNDATION</h3>
                <ul class="slb-dyn-list"></ul>
            </div>
        </div>

        <!-- Footer nav -->
        <div class="cs-slb-footer">
            <button class="cs-slb-nav-btn cs-slb-prev font-monospace">
                <i class="fas fa-chevron-left"></i> PREV
            </button>
            <button class="cs-slb-nav-btn cs-slb-next font-monospace">
                NEXT <i class="fas fa-chevron-right"></i>
            </button>
        </div>

    </div>
</div>

<!-- ================================================== -->
<!-- GLOBAL LIGHTBOX (shared across all case studies)   -->
<!-- ================================================== -->
<div class="cs-lightbox-overlay" id="cs-lightbox" role="dialog" aria-modal="true" aria-label="Result Details">
    <div class="cs-lightbox-panel">
        <div class="cs-lightbox-header">
            <span class="cs-lightbox-counter font-monospace"></span>
            <h3 class="cs-lightbox-title font-monospace text-accent"></h3>
            <button class="cs-lightbox-close" aria-label="Close">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="cs-lightbox-body"></div>
        <div class="cs-lightbox-footer">
            <button class="cs-lb-nav-btn cs-lb-prev">
                <i class="fas fa-chevron-left"></i> PREV_MODULE
            </button>
            <div class="cs-lb-dots"></div>
            <button class="cs-lb-nav-btn cs-lb-next">
                NEXT_MODULE <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </div>
</div>

<!-- TAB NAVIGATION BAR -->
<section id="case-study-nav" class="stack-card case-study-nav-section sticky-top" data-title="CASE_STUDIES">
    <div class="container-fluid px-4 py-3">
        <div class="row justify-content-center">
            <div class="col-xl-10">
                <div class="hud-tabs-wrapper">
                    <div class="nav nav-pills hud-nav-pills justify-content-center gap-3" id="caseStudyTabs" role="tablist">
                        <button class="nav-link active hud-tab-btn" id="tab-classic" data-bs-toggle="pill" data-bs-target="#content-classic" type="button" role="tab" aria-controls="content-classic" aria-selected="true">
                            <span class="tab-marker">///</span>
                            CLASSIC ZAMBIA SAFARIS
                        </button>
                        <button class="nav-link hud-tab-btn" id="tab-house" data-bs-toggle="pill" data-bs-target="#content-house" type="button" role="tab" aria-controls="content-house" aria-selected="false">
                            <span class="tab-marker">///</span>
                            HOUSE TO HOME
                        </button>
                        <button class="nav-link hud-tab-btn" id="tab-bnop" data-bs-toggle="pill" data-bs-target="#content-bnop" type="button" role="tab" aria-controls="content-bnop" aria-selected="false">
                            <span class="tab-marker">///</span>
                            BNOP MEDIA
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CONTENT AREA -->
<div class="tab-content" id="caseStudyTabContent">

    <!-- ========================================== -->
    <!-- CASE STUDY 1: CLASSIC ZAMBIA SAFARIS       -->
    <!-- ========================================== -->
    <div class="tab-pane fade show active" id="content-classic" role="tabpanel" aria-labelledby="tab-classic">

        <!-- SECTION 1: OVERVIEW + CHALLENGE (2-col) -->
        <section id="classic-overview" class="stack-card cs-section cs-section--split" data-title="OVERVIEW">
            <div class="container-fluid px-4 h-100">
                <div class="row justify-content-center h-100">
                    <div class="col-xl-10 d-flex flex-column">
                        <h2 class="section-title font-monospace text-accent text-center fade-in-on-scroll cs-section-heading">/// PROJECT_OVERVIEW</h2>
                        <div class="cs-split-layout flex-1">
                            <!-- LEFT: Stat Cards -->
                            <div class="cs-split-col cs-split-col--left">
                                <div class="cs-col-inner d-flex flex-column gap-3 h-100">
                                    <div class="cs-stat-card flex-1 fade-in-on-scroll">
                                        <div class="stat-label">CLIENT_IDENTITY</div>
                                        <div class="stat-value text-white">Classic Zambia Safaris</div>
                                        <div class="stat-meta">Industry: Tourism</div>
                                    </div>
                                    <div class="cs-stat-card flex-1 fade-in-on-scroll" style="transition-delay: 0.1s;">
                                        <div class="stat-label">TIMEFRAME_LOG</div>
                                        <div class="stat-value text-white">4 MONTHS</div>
                                        <div class="stat-meta">Nov 2025 - Feb 2026</div>
                                    </div>
                                    <div class="cs-stat-card flex-1 fade-in-on-scroll" style="transition-delay: 0.2s;">
                                        <div class="stat-label">OPERATOR_ROLE</div>
                                        <div class="stat-value text-white">FULL_STACK & SEO</div>
                                        <div class="stat-meta">Lead Developer</div>
                                    </div>
                                </div>
                            </div>
                            <!-- DIVIDER -->
                            <div class="cs-split-divider">
                                <span class="font-monospace text-accent" style="font-size:0.7rem; writing-mode: vertical-rl; letter-spacing: 3px; opacity:0.5;">/// THE_CHALLENGE</span>
                            </div>
                            <!-- RIGHT: Challenge Blocks -->
                            <div class="cs-split-col cs-split-col--right">
                                <div class="cs-col-inner">
                                    <div class="challenge-grid row g-3 h-100">
                                        <div class="col-6">
                                            <div class="challenge-block h-100 fade-in-on-scroll">
                                                <div class="challenge-icon"><i class="fas fa-eye-slash"></i></div>
                                                <h4 class="text-white">MINIMAL VISIBILITY</h4>
                                                <p class="text-muted">Zero organic footprint in a saturated market.</p>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="challenge-block h-100 fade-in-on-scroll" style="transition-delay: 0.1s;">
                                                <div class="challenge-icon"><i class="fas fa-battery-quarter"></i></div>
                                                <h4 class="text-white">LOW AUTHORITY</h4>
                                                <p class="text-muted">Domain Rating of 19 struggling to compete.</p>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="challenge-block h-100 fade-in-on-scroll" style="transition-delay: 0.2s;">
                                                <div class="challenge-icon"><i class="fas fa-globe-africa"></i></div>
                                                <h4 class="text-white">GLOBAL TARGETS</h4>
                                                <p class="text-muted">Need to reach US, UK, Australia & Europe.</p>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="challenge-block h-100 fade-in-on-scroll" style="transition-delay: 0.3s;">
                                                <div class="challenge-icon"><i class="fas fa-filter"></i></div>
                                                <h4 class="text-white">QUALIFIED LEADS</h4>
                                                <p class="text-muted">High traffic bounce rate with low conversion.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION 2: GOALS + APPROACH (2-col) -->
        <section id="classic-approach" class="stack-card cs-section cs-section--split" data-title="APPROACH">
            <div class="container-fluid px-4 h-100">
                <div class="row justify-content-center h-100">
                    <div class="col-xl-10 d-flex flex-column">
                        <h2 class="section-title font-monospace text-accent text-center fade-in-on-scroll cs-section-heading">/// OBJECTIVES_&_APPROACH</h2>
                        <div class="cs-split-layout flex-1">
                            <!-- LEFT: Goals -->
                            <div class="cs-split-col cs-split-col--left">
                                <div class="cs-col-inner d-flex flex-column">
                                    <div class="cs-col-label font-monospace text-accent mb-3">BUSINESS_OBJECTIVES</div>
                                    <div class="goals-grid stagger-container flex-1">
                                        <div class="goal-card">
                                            <div class="goal-marker"><i class="fas fa-crosshairs"></i></div>
                                            <div class="goal-content">
                                                <h5 class="text-white">TRAFFIC ACQUISITION</h5>
                                                <p class="text-muted mb-0">Increase organic traffic from international markets (US, EU, AU).</p>
                                            </div>
                                        </div>
                                        <div class="goal-card">
                                            <div class="goal-marker"><i class="fas fa-crosshairs"></i></div>
                                            <div class="goal-content">
                                                <h5 class="text-white">SERP DOMINANCE</h5>
                                                <p class="text-muted mb-0">Improve search rankings for high-value safari keywords.</p>
                                            </div>
                                        </div>
                                        <div class="goal-card">
                                            <div class="goal-marker"><i class="fas fa-crosshairs"></i></div>
                                            <div class="goal-content">
                                                <h5 class="text-white">AUTHORITY BUILDING</h5>
                                                <p class="text-muted mb-0">Build domain authority to compete with established legacy operators.</p>
                                            </div>
                                        </div>
                                        <div class="goal-card">
                                            <div class="goal-marker"><i class="fas fa-crosshairs"></i></div>
                                            <div class="goal-content">
                                                <h5 class="text-white">CONVERSION OPTIMIZATION</h5>
                                                <p class="text-muted mb-0">Generate qualified leads for high-value luxury safari bookings.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- DIVIDER -->
                            <div class="cs-split-divider">
                                <span class="font-monospace text-accent" style="font-size:0.7rem; writing-mode: vertical-rl; letter-spacing: 3px; opacity:0.5;">/// STRATEGIC_APPROACH</span>
                            </div>
                            <!-- RIGHT: Slider -->
                            <div class="cs-split-col cs-split-col--right">
                                <div class="cs-col-inner d-flex flex-column">
                                    <div class="cs-col-label font-monospace text-accent mb-3">STRATEGIC_APPROACH</div>
                                    <div class="strategy-slider-wrapper fade-in-on-scroll flex-1">
                                        <button class="slider-control prev-btn"><i class="fas fa-chevron-left"></i></button>
                                        <div class="slider-track-container">
                                            <div class="slider-track">
                                                <div class="strategy-card card-type-a" data-sg="strategy-classic" data-si="0">
                                                    <div class="card-chip">MOD_4A</div>
                                                    <div class="card-icon"><i class="fas fa-cogs"></i></div>
                                                    <h4>TECH SEO FOUNDATION</h4>
                                                    <button class="strategy-lb-btn font-monospace" type="button">[ VIEW_MODULE ]</button>
                                                </div>
                                                <div class="strategy-card card-type-b" data-sg="strategy-classic" data-si="1">
                                                    <div class="card-chip">MOD_4B</div>
                                                    <div class="card-icon"><i class="fas fa-search-plus"></i></div>
                                                    <h4>ON-PAGE OPTIMIZATION</h4>
                                                    <button class="strategy-lb-btn font-monospace" type="button">[ VIEW_MODULE ]</button>
                                                </div>
                                                <div class="strategy-card card-type-c" data-sg="strategy-classic" data-si="2">
                                                    <div class="card-chip">MOD_4C</div>
                                                    <div class="card-icon"><i class="fas fa-pen-nib"></i></div>
                                                    <h4>CONTENT STRATEGY</h4>
                                                    <button class="strategy-lb-btn font-monospace" type="button">[ VIEW_MODULE ]</button>
                                                </div>
                                                <div class="strategy-card card-type-d" data-sg="strategy-classic" data-si="3">
                                                    <div class="card-chip">MOD_4D</div>
                                                    <div class="card-icon"><i class="fas fa-link"></i></div>
                                                    <h4>LINK AUTHORITY</h4>
                                                    <button class="strategy-lb-btn font-monospace" type="button">[ VIEW_MODULE ]</button>
                                                </div>
                                                <div class="strategy-card card-type-e" data-sg="strategy-classic" data-si="4">
                                                    <div class="card-chip">MOD_4E</div>
                                                    <div class="card-icon"><i class="fas fa-chart-line"></i></div>
                                                    <h4>PERFORMANCE MON</h4>
                                                    <button class="strategy-lb-btn font-monospace" type="button">[ VIEW_MODULE ]</button>
                                                </div>
                                            </div>
                                        </div>
                                        <button class="slider-control next-btn"><i class="fas fa-chevron-right"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Hidden strategy lightbox content pool -->
                        <div class="strategy-lb-pool d-none" data-sg="strategy-classic">
                            <div class="strategy-lb-item" data-si="0" data-type="a" data-chip="MOD_4A" data-icon="fas fa-cogs" data-title="TECH SEO FOUNDATION">
                                <ul>
                                    <li>Site audit (40+ technical issues)</li>
                                    <li>Core Web Vitals (4.2s → 1.8s)</li>
                                    <li>Schema markup for tourism</li>
                                    <li>Site architecture optimization</li>
                                    <li>Fixed broken links/redirects</li>
                                </ul>
                            </div>
                            <div class="strategy-lb-item" data-si="1" data-type="b" data-chip="MOD_4B" data-icon="fas fa-search-plus" data-title="ON-PAGE OPTIMIZATION">
                                <ul>
                                    <li>Rewrote meta titles (60+ pages)</li>
                                    <li>Image alt tags with keywords</li>
                                    <li>Long-tail keyword strategy</li>
                                    <li>Breadcrumb navigation</li>
                                    <li>FAQ schema integration</li>
                                </ul>
                            </div>
                            <div class="strategy-lb-item" data-si="2" data-type="c" data-chip="MOD_4C" data-icon="fas fa-pen-nib" data-title="CONTENT STRATEGY">
                                <ul>
                                    <li>High-value keywords: "Zambia safaris"</li>
                                    <li>Location-specific landing pages</li>
                                    <li>Buyer's guide content</li>
                                    <li>Seasonal content strategy</li>
                                    <li>Search intent optimization</li>
                                </ul>
                            </div>
                            <div class="strategy-lb-item" data-si="3" data-type="d" data-chip="MOD_4D" data-icon="fas fa-link" data-title="LINK AUTHORITY">
                                <ul>
                                    <li>Tourism directory backlinks</li>
                                    <li>Safari operator partnerships</li>
                                    <li>Shareable resources</li>
                                    <li>Toxic backlink monitoring</li>
                                </ul>
                            </div>
                            <div class="strategy-lb-item" data-si="4" data-type="e" data-chip="MOD_4E" data-icon="fas fa-chart-line" data-title="PERFORMANCE MON">
                                <ul>
                                    <li>Google Search Console setup</li>
                                    <li>Ahrefs monitoring</li>
                                    <li>GA4 conversion tracking</li>
                                    <li>Monthly reporting dashboards</li>
                                </ul>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION 3: RESULTS (4-card lightbox triggers) -->
        <section id="classic-results" class="stack-card cs-section cs-section--results" data-title="RESULTS">
            <div class="container-fluid px-4 h-100">
                <div class="row justify-content-center h-100">
                    <div class="col-xl-10 d-flex flex-column">
                        <h2 class="section-title font-monospace text-accent text-center fade-in-on-scroll cs-section-heading">/// MISSION_RESULTS</h2>

                        <!-- 4 Trigger Cards -->
                        <div class="cs-result-triggers flex-1">
                            <div class="cs-result-trigger fade-in-on-scroll" data-lb-group="classic" data-lb-index="0" role="button" tabindex="0">
                                <div class="trigger-accent-line"></div>
                                <div class="trigger-icon"><i class="fas fa-chart-bar"></i></div>
                                <div class="trigger-body">
                                    <div class="trigger-code font-monospace">MODULE_01</div>
                                    <h4 class="trigger-label">TRAFFIC_GROWTH</h4>
                                    <p class="trigger-meta text-muted">Clicks, sessions, countries & growth metrics</p>
                                </div>
                                <div class="trigger-cta font-monospace">ACCESS <i class="fas fa-arrow-right ms-1"></i></div>
                            </div>
                            <div class="cs-result-trigger fade-in-on-scroll" data-lb-group="classic" data-lb-index="1" role="button" tabindex="0" style="transition-delay:0.1s;">
                                <div class="trigger-accent-line"></div>
                                <div class="trigger-icon"><i class="fas fa-list-ol"></i></div>
                                <div class="trigger-body">
                                    <div class="trigger-code font-monospace">MODULE_02</div>
                                    <h4 class="trigger-label">SEARCH_RANKINGS</h4>
                                    <p class="trigger-meta text-muted">Keyword positions, CTR & featured snippets</p>
                                </div>
                                <div class="trigger-cta font-monospace">ACCESS <i class="fas fa-arrow-right ms-1"></i></div>
                            </div>
                            <div class="cs-result-trigger fade-in-on-scroll" data-lb-group="classic" data-lb-index="2" role="button" tabindex="0" style="transition-delay:0.2s;">
                                <div class="trigger-accent-line"></div>
                                <div class="trigger-icon"><i class="fas fa-shield-alt"></i></div>
                                <div class="trigger-body">
                                    <div class="trigger-code font-monospace">MODULE_03</div>
                                    <h4 class="trigger-label">AUTHORITY_&_IMPACT</h4>
                                    <p class="trigger-meta text-muted">Domain rating, backlinks & business outcomes</p>
                                </div>
                                <div class="trigger-cta font-monospace">ACCESS <i class="fas fa-arrow-right ms-1"></i></div>
                            </div>
                            <div class="cs-result-trigger fade-in-on-scroll" data-lb-group="classic" data-lb-index="3" role="button" tabindex="0" style="transition-delay:0.3s;">
                                <div class="trigger-accent-line"></div>
                                <div class="trigger-icon"><i class="fas fa-microchip"></i></div>
                                <div class="trigger-body">
                                    <div class="trigger-code font-monospace">MODULE_04</div>
                                    <h4 class="trigger-label">TECH_SPECS_&_LEARNINGS</h4>
                                    <p class="trigger-meta text-muted">Stack details, toolset & key insights</p>
                                </div>
                                <div class="trigger-cta font-monospace">ACCESS <i class="fas fa-arrow-right ms-1"></i></div>
                            </div>
                        </div>

                        <!-- Hidden lightbox content pool -->
                        <div class="cs-lb-content-pool d-none" data-lb-group="classic">
                            <!-- Module 0: Traffic -->
                            <div class="cs-lb-panel" data-lb-index="0" data-lb-title="TRAFFIC_GROWTH">
                                <div class="row g-4 mb-4">
                                    <div class="col-6 col-md-3">
                                        <div class="result-card">
                                            <div class="result-value text-success counter-animate" data-target="217" data-suffix="%">0</div>
                                            <div class="result-label">ORGANIC INCREASE (61 → 194)</div>
                                        </div>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <div class="result-card">
                                            <div class="result-value text-white counter-animate" data-target="15" data-suffix="+">0</div>
                                            <div class="result-label">COUNTRIES REACHED</div>
                                        </div>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <div class="result-card">
                                            <div class="result-value text-white counter-animate" data-target="987" data-suffix="">0</div>
                                            <div class="result-label">MONTHLY CLICKS</div>
                                        </div>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <div class="result-card">
                                            <div class="result-value text-info">4m 33s</div>
                                            <div class="result-label">AVG SESSION TIME</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Module 1: Rankings -->
                            <div class="cs-lb-panel" data-lb-index="1" data-lb-title="SEARCH_RANKINGS">
                                <div class="tech-spec-grid">
                                    <div class="spec-row">
                                        <span class="spec-key">"Classic Zambia Safaris"</span>
                                        <span class="spec-val text-accent">POS #1-2 (58% CTR)</span>
                                    </div>
                                    <div class="spec-row">
                                        <span class="spec-key">"Kutandala Camp"</span>
                                        <span class="spec-val text-accent">POS #1.63 (40% CTR)</span>
                                    </div>
                                    <div class="spec-row">
                                        <span class="spec-key">Primary Keywords (Top 3)</span>
                                        <span class="spec-val text-white">12+ TERMS</span>
                                    </div>
                                    <div class="spec-row">
                                        <span class="spec-key">"Best binoculars for safari"</span>
                                        <span class="spec-val text-white">Featured Snippet (2.8k Impr)</span>
                                    </div>
                                </div>
                            </div>
                            <!-- Module 2: Authority + Impact -->
                            <div class="cs-lb-panel" data-lb-index="2" data-lb-title="AUTHORITY_&_IMPACT">
                                <div class="row g-4 mb-4">
                                    <div class="col-md-4">
                                        <div class="result-card">
                                            <div class="result-value text-warning">DR 23</div>
                                            <div class="result-label">DOMAIN RATING (Was 19)</div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="result-card">
